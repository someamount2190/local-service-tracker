# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Leave DATABASE_URL UNSET for local development: the app falls back to an
# in-process, file-backed Postgres (PGlite) stored in ./.pglite — no install,
# no Docker, same SQL dialect as production.
#
# In production (Vercel), set DATABASE_URL to a Neon / Vercel Postgres
# connection string. Presence of this var switches the driver automatically.
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/db?sslmode=require"

# Force a driver explicitly (optional): "pglite" or "neon".
# LST_DB="pglite"

# ---------------------------------------------------------------------------
# Scheduled refresh auth
# ---------------------------------------------------------------------------
# Bearer token required to call /api/cron/refresh. Vercel Cron sends this
# automatically when CRON_SECRET is set in project env. Locally any value works.
CRON_SECRET="dev-secret"

# ---------------------------------------------------------------------------
# Real open-data source: GBFS bike-share feed (no API key needed)
# ---------------------------------------------------------------------------
# Base URL of a GBFS "en" feed directory. Default is NYC Citi Bike.
# Find others at https://github.com/MobilityData/gbfs (systems.csv).
GBFS_BASE="https://gbfs.citibikenyc.com/gbfs/en"

# Bounding box to keep the dataset demo-sized & geographically coherent:
# minLng,minLat,maxLng,maxLat. Default ~ Lower/Mid Manhattan.
GBFS_BBOX="-74.02,40.70,-73.96,40.78"

# Hard cap on number of stations imported.
GBFS_LIMIT="80"

# ---------------------------------------------------------------------------
# Lazy refresh
# ---------------------------------------------------------------------------
# How long (seconds) a fetch is considered fresh before a page view will
# opportunistically trigger a background refresh. Also used as the per-source
# minimum interval to respect upstream rate limits / GBFS ttl.
REFRESH_TTL_SECONDS="90"

# Base URL used by `npm run refresh` when posting to the cron endpoint.
REFRESH_TARGET_URL="http://localhost:3000"
